{
  // Text editor
  "files.trimFinalNewlines": true,

  // File associations
  "files.associations": {
    "version": "plaintext"
  },

  // Editor associations
  "workbench.editorAssociations": {
    "*.drawio.svg": "hediet.vscode-drawio-text",
    "*.svg": "imagePreview.previewEditor"
  },

  // Draw.io
  "hediet.vscode-drawio.simpleLabels": true,

  // Markdown
  "markdown.extension.toc.updateOnSave": false,

  // LaTeX
  "latex-workshop.latex.outDir": "%DIR%/build/",
  "latex-workshop.latex.rootFile.useSubFile": true,
  "latex-workshop.message.latexlog.exclude": [
    "Infinite glue shrinkage found in box being split"
  ],  // TeX Live 2025...
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.recipe.default": "lastUsed",
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-cd",
        "-r", "%WORKSPACE_FOLDER%/lib/latex/latexmkrc",
        "-shell-escape",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ],
      "env": {
        "TEXINPUTS": "%WORKSPACE_FOLDER%/lib/latex//;%WORKSPACE_FOLDER%/resources//;"
      }
    },
    {
      "name": "docker-latexmk",
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-v",
        "%WORKSPACE_FOLDER%:/work",
        "-w",
        "/work/%RELATIVE_DIR%",
        "-e",
        "TEXINPUTS=/work/lib/latex//:/work/resources//:",
        "ghcr.io/munuchapterhkn/eta-kappa-notes/texlive",
        "latexmk",
        "-cd",
        "-r",
        "/work/lib/latex/latexmkrc",
        "-shell-escape",
        "-pdf",
        "-outdir=build",
        "%DOCFILE%"
      ]
    }
  ],
  "latex-workshop.latex.recipes": [
    {
      "name": "latexmk",
      "tools": ["latexmk"]
    },
    {
      "name": "docker-latexmk",
      "tools": ["docker-latexmk"]
    }
  ],
  // Typst
  "tinymist.outputPath": "$dir/build/$name"
}
