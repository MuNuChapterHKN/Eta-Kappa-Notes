{
  // Text editor
  "files.trimFinalNewlines": true,

  // Editor associations
  "workbench.editorAssociations": {
      "*.drawio.svg": "hediet.vscode-drawio-text",
      "*.svg": "imagePreview.previewEditor"
  },

  // Draw.io
  "hediet.vscode-drawio.simpleLabels": true,

  // Markdown
  "markdown.extension.toc.updateOnSave": false,

  // LaTeX
  "latex-workshop.latex.outDir": "%DIR%/build/",
  "latex-workshop.latex.rootFile.useSubFile": true,
  "latex-workshop.message.latexlog.exclude": [
      "Infinite glue shrinkage found in box being split"
  ],  // TeX Live 2025 triggers this 'ignored error' when a longtable is split across pages.
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-cd",
        "-r", "%WORKSPACE_FOLDER%/lib/latex/latexmkrc",
        "-shell-escape",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ],
      "env": {
        "TEXINPUTS": "%WORKSPACE_FOLDER%/lib/latex//;%WORKSPACE_FOLDER%/resources/imgs//;"
      }
    }
  ],

  // LTeX+ (LanguageTool)
  // Orthography and grammar checker: only supports one language at a time, but is more powerful than Code Spell Checker
  // (see below), which only supports orthography. Here set to Italian, in order to set language automatically ofr whoever contributes to the project.

  "ltex.language": "it",

  // Code Spell Checker
  // Additional extension, alternative to LTeX+, thats supports bilingual correction, but only for orthography, not grammar.
  // Only one of them should be active at a time, otherwise they will conflict.
  "cSpell.language": "en,it",
  "cSpell.words": [
    "Ndocument",
    "randazzo"
  ]
}
