{
  // TEXT EDITOR
  "files.trimFinalNewlines": true,

  // FILE ASSOCIATIONS
  "files.associations": {
    "version": "plaintext"
  },

  // EDITOR ASSOCIATIONS
  "workbench.editorAssociations": {
    "*.drawio.svg": "hediet.vscode-drawio-text",
    "*.svg": "imagePreview.previewEditor"
  },

  // Draw.io
  "hediet.vscode-drawio.simpleLabels": true,

  // Markdown
  "markdown.extension.toc.updateOnSave": false,

  // LaTeX
  "latex-workshop.latex.outDir": "%DIR%/build/",
  "latex-workshop.latex.rootFile.useSubFile": true,
  "latex-workshop.message.latexlog.exclude": [
      "Infinite glue shrinkage found in box being split",
      "Package everypage Warning: Functionality similar to this package has recently",
      "Package everypage Warning: You appear to be running a version of LaTeX"
    ],
    // ABOVE: IGNORED LATEX WARNINGS LIST (Hidden by VS Code, but they are still printed in the raw LaTeX .log file)
    // 1) TeX Live 2025 triggers this 'ignored error' when a longtable is split across pages.
    // 2) Warning triggered by the usage of the "background" package, which, in turn, calls the "everypage" package.
    //    It is used by the custom class HKNdocument to print an "UNPUBLISHED" watermark on the background of documents
    //    without a specified version. Further details are available in the CONTRIBUTING.md file.
    // 3) Same as above.
  "latex-workshop.latex.tools": [
    {
      "name": "latexmk",
      "command": "latexmk",
      "args": [
        "-cd",
        "-r", "%WORKSPACE_FOLDER%/lib/latex/latexmkrc",
        "-shell-escape",
        "-synctex=1",
        "-interaction=nonstopmode",
        "-file-line-error",
        "-pdf",
        "-outdir=%OUTDIR%",
        "%DOC%"
      ],
      "env": {
        "TEXINPUTS": "%WORKSPACE_FOLDER%/lib/latex//;%WORKSPACE_FOLDER%/resources//;"
      }
    }
  ],

  // TYPST
  "tinymist.outputPath": "$dir/build/$name",

  // LTeX+ ORTHOGRAPHY AND GRAMMAR CHECKER:
  // only supports one language at a time, but is more powerful than Code Spell Checker (see below), which only supports
  // orthography. Here set to Italian, in order to set language automatically ofr whoever contributes to the project.
  "ltex.language": "it",

  // GITLENS EXTENSION
  // Ho rimosso "containers" e "blocks" per evitare i suggerimenti fantasma vicino agli \include del file main.tex,
  // fastidiosissimi. Questi suggerimenti sono quelli del tipo "2 authors (You and one other)". Lasciandoli accesi per
  // document se ne ottiene uno solo all'inizio del documento. La soluzione è stata togliere "containers" precisamente,
  // essendo i containers blocchi logici principali.
  "gitlens.codeLens.scopes": [
      "document"
  ],

  // VSCODE - SETTINGS LOCALI (SCOPE = WORKSPACE)
  // Modifica locale delle impostazioni di VScode, affinché mostri i delimitatori presi di riferimento per scrivere
  // il codice di questo progetto. Sono valori standard, spesso usati, in particolare "80", valore tipico, risalente
  // storicamente ai terminali UNIX, che avevano una larghezza di 80 caratteri. È tutt'ora comodo per quando si divide
  // lo schermo a metà tra due app. "120" è un valore più ampio ragionevole che consente di usare meglio lo schermo
  // intero. Un altro valore molto usato è "100".
  "editor.rulers": [80, 120],

  // CODE SPELL CHECKER (cSpell) EXTENSION
  // Additional extension, alternative to LTeX+, that supports bilingual correction, but only for spelling, not grammar.
  // Only one of them should be active at a time unless scope limitations are set; otherwise, they could conflict.
  // Note that they use different custom dictionaries (files), and that LTeX+ is more powerful than cSpell, as it
  // supports grammar and spell (orthography) checking, while cSpell only supports spell checking. For this reasons,
  // LTeX+ is set as the main and default checker for LaTeX files, while for the same files cSpell is deactivated, or
  // limited to specific roles. Anyway cSpell is still active for other file types, as Commit Messages!
  //
  // Activates bilingual spell checking, in English and Italian.
  "cSpell.language": "en,it",
  // Deactivates Code Spell Checker for LaTeX Ecosystem files. Manual change of cSpell whitelist.
  // NOTE: the following instructions uses language ID objects, that can be obtained by opening command palette
  // (Ctrl+Shift+P), and searching and clicking on "Change Language Mode": search for "tex", and look at all the related
  // IDs shown there. Other ways to open change language mode: click on the language string in the bottom right corner
  // of the VS Code window, or use the keyboard shortcut (key chords, or sequential shortcut: Ctrl+K, M).
  // Some of the IDs shown below are not native to VS Code, but are added by the LaTeX Workshop extension.
  // NOTE: the VS Code native syntax, like "[latex]": {"cSpell.enabled": false} (on multiple lines) it is not supported.
  // NOTE: cSpell recently changed syntax for this instruction. It was array-based, like (on more rows)
  // "cSpell.enableFiletypes": ["!latex", "!tex", "!bibtex"], which now does not work anymore. Today is object-based.

  //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////
  /*
  UPDATE: RE-ENABLE CSPELL ONLY FOR FILE TYPES WHERE WE WANT TO READ COMMENTS: CSPELL SURGICAL APPROACH.
  Explanations for the selected IDs / Native cSpell / Native LTeX+ / Surgical cSpell for comments:
  - latex, tex: Standard files (.tex). Nat. cSpell: Active. Nat. LTeX+: Active. Surgical: YES.
  - latex-class, latex-package: Classes (.cls) and packages (.sty). Nat. cSpell: Active?. Nat. LTeX+: Active.
    Surgical: YES.
  - latex-expl3: Modern LaTeX3 programming scripts. Nat. cSpell: Inactive. Nat. LTeX+: Struggles. Surgical: YES.
  - doctex: Documented LaTeX source files (.dtx). Nat. cSpell: Inactive. Nat. LTeX+: Active. Surgical: YES.
  - context: ConTeXt typesetting system files. Nat. cSpell: Inactive. Nat. LTeX+: Active. Surgical: YES.
  - bibtex, biblatex: Bibliography databases (.bib). Nat. cSpell: Inactive. Nat. LTeX+: Active. Surgical: NO
    (disabled to avoid false positives on foreign names and titles).
  - bibtex-style: BibTeX styles (.bst). Nat. cSpell: Inactive. Nat. LTeX+: Inactive. Surgical: NO.
  - doctex-installer, markdown_latex_combined, cpp_embedded_latex, latex_workshop_log: Installers, logs, hybrid
    files. Nat. cSpell: Inactive. Nat. LTeX+: Active (Markdown)/Inactive. Surgical: NO (prevents conflicts/errors).
  - json, jsonc: JSON and JSON with Comments files. Nat. cSpell: Active. Nat. LTeX+: Inactive. Surgical: YES.
  NOTE: Explicitly setting "true" ensures custom IDs provided by the extensions are always checked, overriding
  cSpell's default internal whitelist.
  NOTE: WHY cSpell? HAS LTeX+ GOT AN OPTION TO CHECK COMMENTS TOO? No, LTeX+ does not have a built-in option to check
  for LaTeX comments: its LaTeX comment ignoring logic its hardcoded and cannot be modified by options. Anyway, even if
  it were possible to enabled it, grammar checking for comments would be a nightmare: not recommended. LTeX+ docs
  report that the extension can also check only comments in other programming languages (using ltex.enabled, putting
  Language IDs of non-LaTeX files), but does the exact opposite on LaTeX files, where it checks only code and ignores
  comments.
  */
  "cSpell.enabledFileTypes": {
      "latex": true,
      "tex": true,
      "latex-class": true,
      "latex-package": true,
      "latex-expl3": true,
      "doctex": true,
      "context": true,
      "bibtex": false,
      "biblatex": false,
      "bibtex-style": false,
      "doctex-installer": false,
      "markdown_latex_combined": false,
      "cpp_embedded_latex": false,
      "latex_workshop_log": false,
      "json": true,
      "jsonc": true
  },
  // SURGICAL MODE: For the activated languages above, tell cSpell to read ONLY the comments. Implemented using regular
  // expressions (RegEx): special string patterns that cSpell will use to identify the text to be checked.
  // [NOTE: this comment cannot be transformed into a multi-line json comment because it contains the "/*...*/" string]
  //
  // --- DETAILED REGEX STRATEGIES FOR CSPELL ---
  //
  // ESCAPE CHARACTER IN JSON - JSON vs REGEX:
  // In JSON files, the backslash ("\") is an escape character. To send a single backslash to the RegEx engine, we must
  // write two of them in the JSON ("\\"). To send two (which the RegEx engine interprets as "find a literal
  // backslash", because it's an escape sequence in RegEx too), we must write four of them ("\\\\").
  //
  // BRACKETS IN REGEX:
  // - ROUND BRACKETS OR PARENTHESES "(...)" - GROUPS: Create a "group", which is a sequence treated by the Regex
  //   engine as a single unified block. It behaves like a sequence or concatenation: it matches exactly the characters
  //   sequence inside, in the exact order they appear. They can be used for multiple purposes:
  //   * Defining a simple string of characters to find as a single unit.
  //   * Calling special command with complex syntax: the parentheses enclose the all the command itself with its
  //     arguments, making them clearly identifiable. These commands are meant to be initiated by a parenthesis, like
  //     the negative lookbehind "(?<!string_to_exclude)" discussed below: when a group starts with "(?", it tells the
  //     engine: "This is a special command, not literal text".
  //   Furthermore, each pair of parentheses creates a "capture group", which is a memory-based feature: they can be
  //   used to "remember the matched string". More precisely, each pair creates a background variable that stores the
  //   matched text in RAM. This can be recalled later (e.g., in the replace field of "Find and Replace") using
  //   specific syntax ($1, $2, etc., for the first, second, etc., group respectively).
  //   The general effect of parentheses is to ADD UP everything inside them into a single unit. One could say they
  //   behave like a "LOGICAL AND", but it is not a perfect analogy: the order of the characters inside strictly
  //   matters, whereas a pure LOGICAL AND would not care about it.
  // - SQUARE BRACKETS OR BRACKETS "[...]" - OPTIONS (CHARACTER CLASSES): Create a list of acceptable options for a
  //   single position, called a "character class". The engine will match ONLY ONE of the characters inside the
  //   brackets. It behaves exactly like a LOGICAL "OR": e.g., "[abc]" matches "a" OR "b" OR "c". Here, the logic
  //   description its exact and not just an analogy: its the way the engine works with square brackets.
  // - CURLY BRACKETS O BRACES "{...}" - QUANTIFIERS: They specify EXACTLY how many times the preceding character,
  //   group, or class must be repeated. For example, "a{3}" matches exactly "aaa". "[0-9]{2,4}" matches between 2 and 4
  //   digits (e.g., "12", "1234").
  // NOTE ON NESTING:
  // Brackets can absolutely be nested to create complex logic! For example, "([A-Z][a-z]{1,5})" is a Group (identified
  // by parentheses) that contains two Character Classes (square) and a Quantifier (curly). It translates to: "Find a
  // sequence starting with one uppercase letter, followed by 1 to 5 lowercase letters, and treat it as a single unit."
  //
  // NEGATIVE LOOKBEHIND REGEX:
  // When a group starts with "(?", it tells the engine: "This is a special command, not literal text". Specifically,
  // the sequence "?<!" in inside "(?<!string_to_exclude)target", means "Negative Lookbehind": the "string_to_exclude"
  // which follows ?<! inside the group is used as a condition to ensure that what precedes the "target" (what follows
  // the group) does NOT match it. Literally, the RegEx engine looks behind the "target" to exclude cases where the
  // specified string_to_exclude is found. This is crucial for our surgical approach, as it allows us to precisely
  // target comments while avoiding false positives in code. See following text for specific examples.
  //
  // 1. LATEX COMMENTS: "(?<!\\\\)%.*" to capture single-line LaTeX comments ("%...").
  // RESULT: Captures everything from "%" to the end of the line, ONLY IF it is a real comment and not an escaped
  // percentage like "\%".
  // - "(?<!\\\\)": The negative lookbehind. It checks that immediately before our target there is NO backslash.
  //   (Note: remember that "\\\\" in JSON becomes "\\" in RegEx, which translates to "find a literal backslash" "\".).
  // - "%": The target. It looks for the literal percent symbol.
  // - ".*": The payload. "." means "any character (except newline)", and "*" means "zero or infinite times".
  // NOTE: LTeX+ is already active for LaTeX block comments written with the "comment" environment, or with the
  // other code-based trick (iffalse, void macro with one argument, etc.) because in both cases is considered as code.
  //
  // 2. JSON/JSONC SINGLE-LINE COMMENTS: "(?<!:)//.*" to capture single-line comments ("//...").
  // RESULT: Captures standard "// comments" but safely ignores URLs like "https://..." inside JSON string values.
  // - "(?<!:)": The negative lookbehind. It ensures there is NO colon (":") immediately before the target.
  // - "//": The target. Looks for two literal forward slashes.
  // - ".*": The payload. Captures everything after the slashes until the end of the line.
  //
  // 3. JSON/JSONC MULTI-LINE COMMENTS: "/\\*[\\s\\S]*?\\*/" to capture block comments ("/*...*/").
  // RESULT: Captures block comments /*...*/ spanning multiple lines, without accidentally eating code between blocks.
  // - "/\\*": The start target. Matches a literal forward slash "/" followed by an asterisk "*". (The asterisk
  //   is a RegEx command meaning "multiply", so it must be escaped to be passed as a literal character: it's done with
  //   a "\" RegEx backslash, which translates in "\\" in JSON (the first backslash escapes the second)).
  // - "[\\s\\S]": The "match absolutely anything" trick. "\s" means "spaces/newlines", "\S" means "non-spaces".
  //   Inside brackets "[...]" they form a character class that means "match a character that is EITHER a space OR a
  //   non-space" (i.e., anything).
  // - "*?": The "Lazy" modifier. "*" says "repeat the previous rule zero or infinite times". The "?" says "but
  //   stop exactly at the VERY FIRST closing tag you find, don't eat the whole file".
  // - "\\*/": The end target. Matches an escaped asterisk "\*" followed by a forward slash "/". Escaped like the first.

  "cSpell.languageSettings": [
      {
          "languageId": "latex,tex,latex-class,latex-package,latex-expl3,doctex,context",
          "includeRegExpList": [
              "(?<!\\\\)%.*"
          ]
      },
      {
          "languageId": "json,jsonc",
          "includeRegExpList": [
              "(?<!:)//.*",
              "/\\*[\\s\\S]*?\\*/"
          ]
      }
  ],
  //////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

  // Deactivates Code Spell Checker for specific files. ADD EXCEPTIONS HERE FOR SPECIFIC FILES, FOLDER, OR FILE
  // EXTENSIONS, IF NEEDED. Example: the string "**/*.cls" means all files with the .cls extension, in any directory or
  // subdirectory. "**" stands for "any directory or subdirectory", while the "*" in "*." stands for "any file name".
  "cSpell.ignorePaths": [
  ],
  // Custom dictionary terms, to avoid false positives. Not used anymore: see the next entry for details.
  "cSpell.words": [
  ],
  // Sets up instructions to use a custom dictionary for the workspace, with the possibility to add words directly from
  // VS code interface.
  // NOTE: Dictionary is created in a dedicated file in the .cspell folder. See the "cSpell.customDictionaries" entry
  // below, to see every detail about the setup. You can use the "HOVER" feature (VS Code), letting mouse hover above
  // a term, to see suggestions for each entry.
  // - "custom-dictionary-workspace" is the name of the custom dictionary JSON object, that can be chosen freely.
  // - "name": specifies the custom dictionary name used internally by cSpell. Best Practice: use the same as above.
  // - "path": specifies the path to the custom dictionary file.
  //   NOTE: "${workspaceFolder:Eta-Kappa-Notes}" is a VS Code substitution variable that points to the root directory
  //   of the project, specifying its name. If the root folder changes its name, or if you want to use the root folder
  //   regardless of its name, you can simply use "${workspaceFolder}" instead. The only disadvantage is that there will
  //   be no specific support for multi-root workspaces (e.g., if you use "Add Folder to Workspace"). NOW SWITCHED TO
  //   GENERIC! Modified "${workspaceFolder:Eta-Kappa-Notes}" to "${workspaceFolder}". Useful if someone renames the
  //   folder on its pc.
  // - ("addWords": true): activates the option to add new words to the dictionary directly from the VS Code interface:
  //   ctrl+. on the highlighted word, or click on the lightbulb icon that appears when hovering the mouse over it.
  // - ("scope": "workspace"): specifies that the custom dictionary is limited to the workspace, and not global.
  // NOTE: This was autocreated using the command palette (Ctrl+Shift+P) and searching for "cSpell: Create Custom
  // Dictionary". Then manually modified to adjust it to the project structure and needs.
  "cSpell.customDictionaries": {
    "HKNdictionary_Elettronica": {  // Project Specific Custom Dictionary for Elettronica di Base Randazzo notes.
      "name": "HKNdictionary_Elettronica",
      "path": "${workspaceFolder}/.cspell/HKNdictionary_Elettronica.txt",
      "addWords": true,
      "scope": "workspace"
    }
  }

  // NOTA BENE: tutte le entries del file .json devono essere separate da una virgola, tranne l'ultima, anche detta
  // "trailing o dangling comma" ("virgola terminale o pendente"), che va omessa!
  // Il file potrebbe funzionare lo stesso, ma essendo un errore di sintassi, la good practice è evitarlo.
}
